<group name="local,custom,nac,">

  <!-- ===================================================================
       Temel kural: Policy Engine'den gelen her JSON logu yakala
       =================================================================== -->
  <rule id="100001" level="0">
    <decoded_as>json</decoded_as>
    <field name="app">policy_engine</field>
    <description>Policy Engine JSON log alındı</description>
  </rule>

  <!-- ===================================================================
       Başarılı yetkilendirme (AUTH_SUCCESS)
       =================================================================== -->
  <rule id="100010" level="3">
    <if_sid>100001</if_sid>
    <field name="event">AUTH_SUCCESS</field>
    <description>NAC: Kullanici yetkilendirildi - VLAN atandi</description>
    <group>authentication_success,</group>
  </rule>

  <!-- ===================================================================
       Başarısız yetkilendirme – tek deneme (AUTH_FAILURE)
       =================================================================== -->
  <rule id="100020" level="5">
    <if_sid>100001</if_sid>
    <field name="event">AUTH_FAILURE</field>
    <description>NAC: Yetkisiz erisim denemesi reddedildi</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- ===================================================================
       Brute-Force: 60 saniyede 4+ başarısız deneme (aynı IP)
       =================================================================== -->
  <rule id="100021" level="10" frequency="4" timeframe="60">
    <if_matched_sid>100020</if_matched_sid>
    <same_field>srcip</same_field>
    <description>KRİTİK AG İHLALİ: Brute-Force / Ardisik kimlik dogrulama hatasi</description>
    <group>authentication_failed,brute_force,attack,</group>
  </rule>

  <!-- ===================================================================
       Rate-Limiter devreye girdi: IP tamamen bloklandı
       =================================================================== -->
  <rule id="100030" level="12">
    <if_sid>100001</if_sid>
    <field name="event">RATE_LIMIT_BLOCKED</field>
    <description>KRİTİK AG İHLALİ: IP adresi rate-limiter tarafindan engellendi (Certificate Spoofing / Brute-Force / Unauthorized Access)</description>
    <group>authentication_failed,brute_force,attack,blocked,</group>
  </rule>

  <!-- ===================================================================
       Devre dışı hesap erişim denemesi
       =================================================================== -->
  <rule id="100040" level="8">
    <if_sid>100020</if_sid>
    <field name="detail">disabled</field>
    <description>NAC: Devre disi hesap ile erisim denemesi</description>
    <group>authentication_failed,policy_violation,</group>
  </rule>

  <!-- ===================================================================
       Bilinmeyen rol / tanımsız kullanıcı erişim denemesi
       =================================================================== -->
  <rule id="100050" level="7">
    <if_sid>100020</if_sid>
    <field name="detail">not found in database</field>
    <description>NAC: Veritabaninda kayitsiz kullanici erisim denemesi</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- ===================================================================
       Orijinal kural korundu (geriye dönük uyumluluk)
       =================================================================== -->
  <rule id="100002" level="3">
    <if_sid>100001</if_sid>
    <field name="message">SECURITY ALERT: Brute-Force</field>
    <options>no_log</options>
    <description>Policy Engine Rate-Limit (eski format)</description>
  </rule>

  <rule id="100003" level="10" frequency="4" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <same_source_ip />
    <description>Policy Engine, Brute-Force saldirisi (eski format)</description>
    <group>authentication_failed,brute_force,</group>
  </rule>

</group>
